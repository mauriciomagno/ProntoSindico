{
  "rules": {
    "usuarios": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid == $uid || root.child('usuarios').child(auth.uid).child('role').val() == 'administrador' || root.child('usuarios').child(auth.uid).child('role').val() == 'sindico')"
      }
    },

    "areas_comuns": {
      ".read": "auth != null",
      "$areaId": {
        ".write": "auth != null && (root.child('usuarios').child(auth.uid).child('role').val() == 'administrador' || root.child('usuarios').child(auth.uid).child('role').val() == 'sindico' || root.child('usuarios').child(auth.uid).child('role').val() == 'tesoureiro')"
      }
    },

    "reservas": {
      ".read": "auth != null",
      "$reservaId": {
        ".write": "auth != null && (data.child('userId').val() == auth.uid || newData.child('userId').val() == auth.uid || root.child('usuarios').child(auth.uid).child('role').val() == 'administrador' || root.child('usuarios').child(auth.uid).child('role').val() == 'sindico' || root.child('usuarios').child(auth.uid).child('role').val() == 'tesoureiro')"
      }
    },

    "boletos": {
      ".read": "auth != null",
      "$moradorId": {
        ".write": "auth != null && (root.child('usuarios').child(auth.uid).child('role').val() == 'administrador' || root.child('usuarios').child(auth.uid).child('role').val() == 'sindico' || root.child('usuarios').child(auth.uid).child('role').val() == 'tesoureiro')"
      }
    },

    "moradores": {
      ".read": "auth != null",
      "$moradorId": {
        ".write": "auth != null && (root.child('usuarios').child(auth.uid).child('role').val() == 'administrador' || root.child('usuarios').child(auth.uid).child('role').val() == 'sindico')"
      }
    },

    "mural_avisos": {
      ".read": "auth != null",
      "$authorUid": {
        ".write": "auth != null && auth.uid == $authorUid && (root.child('usuarios').child(auth.uid).child('role').val() == 'administrador' || root.child('usuarios').child(auth.uid).child('role').val() == 'sindico' || root.child('usuarios').child(auth.uid).child('role').val() == 'tesoureiro')"
      }
    },

    "comunicados": {
      ".read": "auth != null",
      "$authorUid": {
        ".write": "auth != null && auth.uid == $authorUid && (root.child('usuarios').child(auth.uid).child('role').val() == 'administrador' || root.child('usuarios').child(auth.uid).child('role').val() == 'sindico' || root.child('usuarios').child(auth.uid).child('role').val() == 'tesoureiro')"
      }
    },

    "config": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('usuarios').child(auth.uid).child('role').val() == 'administrador' || root.child('usuarios').child(auth.uid).child('role').val() == 'sindico')"
    }
  }
}
